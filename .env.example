# Claude Code MCP Environment Variables
# Copy this file to .env and fill in your values.
# These variables are expanded inside .mcp.json via ${VAR:-default} syntax.

# Context7 API key (optional — higher rate limits for the context7 MCP server)
# Get your key from: https://context7.com/dashboard
CONTEXT7_API_KEY=""

# Root directory the filesystem MCP server is allowed to access.
# Defaults to this repository's path if unset (see .mcp.json).
# MCP_FS_ROOT="D:/src/github/claude-agentic-framework"
