# Ignore everything
/*

# But not these files
!/claude.json
!/CLAUDE.md
!/.gitignore
!/README.md
!/CONTRIBUTING.md
!/.env.example
!/SECURITY_AUDIT.md
!/security-check.sh
!/.mcp.json
!/settings.template.json

# And not these directories and their contents
!/agents/
!/commands/
!/docs/
!/hooks/
!/skills/
!/scripts/
!/tests/
!/.github/

# Explicitly ignore files at the root that should not be tracked
/settings.json
/settings.local.json
/.credentials.json
/.env

# Explicitly ignore directories at the root that should not be tracked
/plugins/
/projects/
/shell-snapshots/
/statsig/
/todos/
/backup/
/hooks-v1-archived/
/hooks-active
/ide/